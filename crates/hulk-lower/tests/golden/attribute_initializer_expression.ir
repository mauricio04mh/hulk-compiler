}
method Box.get #2 -> Number {
  param %p0: Box name=self
  temp %t0: Number
  temp %t1: Number
  temp %t2: Number

  %t0 = getattr %p0, #1
  %t1 = getattr %p0, #2
  %t2 = getattr %p0, #0
