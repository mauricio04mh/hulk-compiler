.TYPES
type Box #0 {
  attr #0 value: Number
  attr #1 a: Number
  attr #2 b: Number
  method #0 get : Box_get
}

.DATA
  <empty>

.CODE
entry #0
function entry #0 -> Object {
  local %l0: Box name=b
  temp %t0: Box
  temp %t1: Number
  temp %t2: Object

  %t0 = allocate Box
  %t0 = static_call Box_init(%t0, 3, 4)
  %l0 = %t0
  %t1 = vcall %l0.Box::get#0(%l0)
  %t2 = call print(%t1)
