}
function Box_init #1 -> Box {
  param %p0: Box name=self
  param %p1: Number name=a
  param %p2: Number name=b
  temp %t0: Number
  temp %t1: Number

  %t0 = %p2 * 2
  %t1 = %p1 + %t0
  setattr %p0, #0, %t1
  setattr %p0, #1, %p1
